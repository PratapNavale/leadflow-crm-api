generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  ADMIN
  MANAGER
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      RoleType @default(SALES)

  createdAt DateTime @default(now())

  leads     Lead[]
}

model Lead {
  id         Int         @id @default(autoincrement())

  name       String
  email      String
  phone      String?
  company    String?

  status     LeadStatus  @default(NEW)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  assignedTo Int?

  user       User?       @relation(fields: [assignedTo], references: [id])
}